---
const name = "Rutuja Bhure";

const projects = [
  {
    title: "Pricing A/B Test & Causal Analysis",
    description: [
      "Designed and simulated an end-to-end A/B test on 5,000 institutional clients to measure whether showing fee tier progress nudges users to trade more.",
      "Estimated causal treatment effect using CUPED variance reduction (cut variance ~50%, equivalent to 2× sample size) and validated with three robustness tests (Welch's t-test, Mann-Whitney, permutation).",
      "Decomposed revenue impact into volume effect vs. rate compression effect, revealing that blanket rollout destroys margin while targeted rollout (clients 10–20% from tier boundary) generates +11% net revenue.",
      "Identified a retention insight: clients closest to tier thresholds showed 60% lower churn despite minimal short-term revenue.",
      "Detected effect decay of ~2%/week using survival analysis, preventing naive annualization that would have overstated ROI by ~40%"
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/revenue-tier-and-churn-experiment" },
    ]
  },
  {
    title: "End-to-End Market Intelligence Pipeline (ELT)",
    description: [
      "Engineered an automated ELT infrastructure using Airflow to ingest market data from CoinGecko into PostgreSQL; implemented custom retry logic and idempotent upserts to ensure 100% data consistency across daily runs.",
      "Architected a 3-layer dbt project (staging, intermediate, marts) to transform raw data into analysis-ready features, including rolling volatility and volume anomaly detection (>2σ thresholds).",
      "Automated the deployment of Apache Superset via Python scripts to pre-configure dashboards and SQL Lab, enabling immediate stakeholder access to 'mart-layer' metrics."
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/crypto-market-analysis?tab=readme-ov-file#crypto-market-intelligence-pipeline" },
    ]
  },
  {
    title: "Retention Targeting & Risk Scoring",
    description: [
      "Built an end-to-end churn prediction system on 7,000+ telecom customers, surfacing that month-to-month contract holders churn at 75% vs. 3% for two-year contracts.",
      "Compared 8 classification models (Logistic Regression, XGBoost, LightGBM, Neural Networks, etc.) using ROC-AUC as the primary metric to handle 26.5% class imbalance; Neural Network achieved 87% accuracy.",
      "Applied SMOTE to correct class imbalance and backward stepwise feature elimination to identify tenure, technical support, and total charges as the strongest churn signals.",
      "Translated model outputs into a retention targeting framework: selectively apply offers to high-risk segments rather than broad campaigns, reducing acquisition cost (new customer acquisition costs 5× more than retention).",
      "Deployed an interactive Streamlit app enabling non-technical stakeholders to score individual customers and explore churn risk in real time."
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/telco-customer-churn" }
    ]
  },
  {
    title: "End-to-End NLP Pipeline to Discover a Contrarian Stock Market Signal",
    description: [
      "Discovered a statistically significant contrarian alpha signal by building an NLP pipeline that analyzed sentiment in SEC filings with FinBERT, validating predictive power on forward returns through cross-sectional regression and Information Coefficient (IC) tests.",
      "Constructed and backtested a long-short portfolio strategy based on the validated signal, implementing rigorous walk-forward analysis with TimeSeriesSplit to prevent lookahead bias and benchmarking performance using metrics like the Sharpe ratio.",
      "Engineered six novel sentiment-based factors (e.g., sentiment skew, QoQ shift) from unstructured text data and evaluated their predictive power and multicollinearity for use in quantitative equity models.",
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/alpha-signal-pipeline" }
    ]
  },
  {
    title: "Probabilistic Inference + Network Analysis (bnlearn, gRain, igraph)",
    description: [
      "Modeled probabilistic dependencies across disease and survey datasets using directed acyclic graphs (DAGs), applying structure learning and exact inference to reason under uncertainty.",
      "Implemented community detection algorithms to identify latent variable clusters within network graphs; validated learned structures against domain priors.",
      "Applied Bayesian inference to propagate evidence through networks, quantifying conditional probabilities for downstream classification tasks."
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/bayesian-networks/blob/main/CapstoneAssignment.pdf" },
    ]
  }
  
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={`${name} - Projects`}>
  <title>Projects | {name}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    :root {
      --text-primary: #37352f;
      --text-secondary: #787774;
      --text-link: #2eaadc;
      --bg-primary: #ffffff;
      --bg-secondary: #f7f6f3;
      --bg-hover: #eeeeec;
      --border-color: #e9e9e7;
      --red-header: rgba(2, 146, 123, 1);
      --nav-tab-bg: rgba(35, 131, 226, 0.07);
      --nav-tab-hover: rgba(35, 131, 226, 0.14);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol";
      background-color: var(--bg-primary);
      color: var(--text-primary);
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    a {
      color: var(--text-link);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    img {
      image-rendering: auto;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      transform: translateZ(0);
    }

    /* Header */
    .header {
      background: var(--bg-primary);
      padding: 10px 96px;
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .header-title {
      font-size: 14px;
      font-weight: 400;
      color: var(--text-primary);
      text-decoration: none;
    }

    .header-title:hover {
      text-decoration: underline;
    }

    /* Main container */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 80px 96px 100px;
    }

    @media (max-width: 900px) {
      .header {
        padding: 10px 24px;
      }
      .main {
        padding: 40px 24px 60px;
        max-width: 100%;
      }
    }

    /* Page Title */
    .page-title {
      font-size: 40px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .page-subtitle {
      color: var(--text-secondary);
      font-size: 16px;
      margin-bottom: 40px;
      line-height: 1.6;
    }

    /* Section Header */
    .section-header {
      font-size: 24px;
      font-weight: 600;
      color: var(--red-header);
      margin-bottom: 20px;
    }

    /* Projects Section */
    .projects-section {
      margin-bottom: 48px;
    }

    .project-item {
      padding: 24px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .project-item:first-of-type {
      padding-top: 0;
    }

    .project-item:last-child {
      border-bottom: none;
    }

    .project-content h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 6px;
      line-height: 1.5;
    }

    .project-description {
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 12px;
      line-height: 1.6;
      padding-left: 0;
      list-style-position: outside;
      margin-left: 0px;
    }

    .project-description li {
      margin-bottom: 8px;
    }

    .project-links {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      background: rgba(228, 244, 249, 1);
      border: 1px solid rgba(228, 244, 249, 1);
      border-radius: 3px;
      font-size: 14px;
    }

    .project-links a {
      color: rgba(124, 130, 129, 1);
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 24px 0;
      border-top: 1px solid var(--border-color);
      margin-top: 48px;
    }

    .footer p {
      color: var(--text-secondary);
      font-size: 14px;
      margin: 0;
      line-height: 1.8;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 16px;
      color: var(--text-secondary);
      font-size: 14px;
      transition: color 0.15s ease;
    }

    .back-link:hover {
      color: var(--text-link);
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-content">
      <a href="/" class="header-title">{name}</a>
    </div>
  </header>

  <!-- Main Content -->
  <main class="main">
    <!-- Page Title -->
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">A collection of my work and contributions</p>

    <!-- All Projects -->
    <h2 class="section-header">All Projects</h2>
    <section class="projects-section">
      {projects.map(project => (
        <article class="project-item">
          <div class="project-content">
            <h3>{project.title}</h3>
            <ul class="project-description">
              {project.description.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="project-links">
              <span>📁</span>
              {project.links.map((link, i) => (
                <>
                  <a href={link.url}>[{link.label}]</a>{i < project.links.length - 1 ? ", " : ""}
                </>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Footer -->
    <footer class="footer">
      <a href="/" class="back-link">← Back to Home</a>
      <p>©{name}, {new Date().getFullYear()}</p>
      <p>All Rights Reserved</p>
    </footer>
  </main>
</body>
</html>
