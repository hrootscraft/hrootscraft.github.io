---
// Portfolio - Edit your information below
const name = "Rutuja Bhure";
const email = "rutuja1675@gmail.com";
const tagline = "Building innovative solutions with code";
const affiliation = "@Blackstone Launchpad";


const socialLinks = {
  resume: "https://docs.google.com/document/d/1PF_lNC3eLivs5qtlhbuykL478KvvXsLUzlfz6_dAfWI/edit?usp=sharing",
  github: "https://github.com/hrootscraft",
  linkedin: "https://linkedin.com/in/rutujabhure",
  twitter: "https://twitter.com/hrootscraft",
};

const aboutMe = [
`I’m Rutuja Bhure, a Product Data Scientist with an MS in Data Science from University at Buffalo. I help teams answer questions like: What should we build next? How do we know it worked? Why did it move (or not move) the metric? What should we do differently?`,
`My work spans the full decision loop: defining north-star and guardrail metrics, designing and analyzing experiments (A/B tests when possible, quasi-experiments and causal inference when not), and translating results into clear recommendations leaders can act on. I also care deeply about correctness and reproducibility—instrumentation, data quality checks, and automated pipelines—so dashboards and metrics stay trustworthy over time.`,
`Recently, I’ve worked on experimentation, retention/churn analysis, and forecasting, building self-serve reporting that helps teams monitor activation, retention, and monetization in real time. Outside of work, I enjoy hiking, taking photos, and learning new skills.`
];

const experience = [
  {
    title: "Product Data Scientist",
    company: "UBuffalo CoLab Powered by Blackstone LaunchPad",
    type: "Part-time",
    duration: "Aug 2024 - Dec 2025 · 1 yr 5 mos",
    location: "New York · On-site",
    description: [
      "Designed and automated A/B-testing and causal-inference pipelines (p-value adjustment, uplift modeling) that raised founder-to-pilot conversion by 19% and informed dynamic-pricing roll-outs across four ventures.",
      "Built revenue-forecasting ensembles (XGBoost, Prophet) improving cash-flow accuracy 40% and shortening fund-raising timelines by two weeks on average.",
      "Developed clustering and RFM segmentation workflows in Python (Scikit-Learn, SHAP) that uncovered three high-LTV niches, lifting CAC-adjusted growth 25% for early-stage startups.",
      "Collaborated with engineering to implement event instrumentation and self-serve dashboards so founders could monitor activation, retention and monetization in real time."
    ],
    skills: ["Causal Inference", "Experimental Design", "Machine Learning", "Statistical Data Analysis",  "Time Series Analysis", "Survival Analysis", "Data Analysis", "SQL", "KPI Reporting"]
  },
  {
    title: "Machine Learning Engineer",
    company: "KSRA (Robotics)",
    type: "Full-time",
    duration: "2023 - 2023 · less than a year",
    location: "Remote",
    description: [
      "Analyzed IoT sensor data to pinpoint indicators of failure modes in industrial robots. Augmented data by running 1000 parallel simulations to generate diverse fault positions. Extracted features from trajectory angles, temperature, torque, and vibrations, including peak frequency and signal-to-noise ratio.",
      "Developed ML models to directly predict the likelihood of failure. Incorporated time-series forecasting to account for temporal patterns in sensor data and capture evolving failure trends; considered Long Short-Term Memory (LSTM) networks for handling sequential data. Assessed AUC-ROC curve, and F1-score to ensure reliable failure predictions. The end result was a 38% reduction in downtime.",
      "Optimized resource allocation through linear programming, incorporating insights from arXiv research papers within the realm of operations research and supply chain management."
    ],
    skills: ["Machine Learning", "MATLAB", "Demand Forecasting", "Deep Learning", "Time Series Analysis", "Statistical Data Analysis"]
  },
  {
    title: "Back End Developer",
    company: "Dezy It, Inc.",
    type: "Full-time",
    duration: "2022 - 2022 · less than a year",
    location: "Remote",
    description: [
      "Designed and developed the database, ensuring optimal performance and scalability for the web application.",
      "Developed APIs for Google authentication, utilized socket.io to enable real-time updates to the web application, implemented automated email functionality upon user logins and signups, thereby improving user experience and retention.",
      "Spearheaded the creation of a customer and product analytics dashboard, collaborating seamlessly with the marketing team to integrate key performance indicators (KPIs) and leveraging optimized SQL queries to efficiently present data, empowering stakeholders to make informed decisions that significantly propelled the sales funnel.",
      "Utilized a range of programming languages, frameworks, protocols, including Javascript, Node.js, React.js, OAuth2.0, SQL to deliver high-quality solutions."
    ],
    skills: ["React.js", "REST APIs", "SQL", "Node.js", "MongoDB", "Database Development"]
  }
];

const topProjects = [
  {
    title: "Pricing A/B Test & Causal Analysis",
    description: [
      "Designed and simulated an end-to-end A/B test on 5,000 institutional clients to measure whether showing fee tier progress nudges users to trade more.",
      "Estimated causal treatment effect using CUPED variance reduction (cut variance ~50%, equivalent to 2× sample size) and validated with three robustness tests (Welch's t-test, Mann-Whitney, permutation).",
      "Decomposed revenue impact into volume effect vs. rate compression effect, revealing that blanket rollout destroys margin while targeted rollout (clients 10–20% from tier boundary) generates +11% net revenue.",
      "Identified a retention insight: clients closest to tier thresholds showed 60% lower churn despite minimal short-term revenue.",
      "Detected effect decay of ~2%/week using survival analysis, preventing naive annualization that would have overstated ROI by ~40%"
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/revenue-tier-and-churn-experiment" },
    ]
  },
  {
    title: "End-to-End Market Intelligence Pipeline (ELT)",
    description: [
      "Engineered an automated ELT infrastructure using Airflow to ingest market data from CoinGecko into PostgreSQL; implemented custom retry logic and idempotent upserts to ensure 100% data consistency across daily runs.",
      "Architected a 3-layer dbt project (staging, intermediate, marts) to transform raw data into analysis-ready features, including rolling volatility and volume anomaly detection (>2σ thresholds).",
      "Automated the deployment of Apache Superset via Python scripts to pre-configure dashboards and SQL Lab, enabling immediate stakeholder access to 'mart-layer' metrics."
    ],
    links: [
      { label: "GITHUB", url: "https://github.com/hrootscraft/crypto-market-analysis?tab=readme-ov-file#crypto-market-intelligence-pipeline" },
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={`${name} - Portfolio`}>
  <title>{name}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    :root {
      --text-primary: #37352f;
      --text-secondary: #787774;
      --text-link: #2eaadc;
      --bg-primary: #ffffff;
      --bg-secondary: #f7f6f3;
      --bg-hover: #eeeeec;
      --border-color: #e9e9e7;
      --red-header: rgba(2, 146, 123, 1);
      --green-header: rgba(2, 146, 123, 1);
      --nav-tab-bg: rgba(35, 131, 226, 0.07);
      --nav-tab-hover: rgba(35, 131, 226, 0.14);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol";
      background-color: var(--bg-primary);
      color: var(--text-primary);
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    a {
      color: rgba(124, 130, 129, 1);
      text-decoration: underline;
    }

    /* Header - Notion style */
    .header {
      background: var(--bg-primary);
      padding: 10px 96px;
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .header-title {
      font-size: 14px;
      font-weight: 400;
      color: var(--text-primary);
    }

    /* Main container */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 80px 96px 100px;
    }

    @media (max-width: 900px) {
      .header {
        padding: 10px 24px;
      }
      .main {
        padding: 40px 24px 60px;
        max-width: 100%;
      }
    }

    /* Page Title */
    .page-title {
      font-size: 32px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 16px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border-color);
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    /* Navigation Tabs - Notion callout style */
    .nav-tabs {
      display: flex;
      flex-direction: row;
      gap: 16px;
      margin-bottom: 0;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border-color);
    }

    .nav-tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 10px;
      background: rgba(228, 244, 249, 1);
      border: 1px solid rgba(228, 244, 249, 1);
      border-radius: 3px;
      color: var(--text-primary);
      font-size: 14px;
      text-decoration: none;
      flex: 1;
    }

    .nav-tab-icon {
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #57564F;
    }
    .nav-tab-icon svg {
      width: 18px;
      height: 18px;
      fill: #57564F;
    }

    /* Profile Section */
    .profile-section {
      display: flex;
      gap: 16px;
      margin-top: 20px;
      margin-bottom: 20px;
    }

    @media (max-width: 600px) {
      .profile-section {
        flex-direction: column;
      }
    }

    .profile-image {
      width: 180px;
      flex-shrink: 0;
    }

    .profile-image img {
      width: 100%;
      height: auto;
      display: block;
    }

    .profile-info {
      padding-top: 0;
    }

    .profile-email {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 12px;
    }

    .profile-email a {
      color: #9b9a97;
      text-decoration: none;
    }

    .profile-tagline {
      font-style: italic;
      color: var(--text-primary);
      margin-bottom: 2px;
      font-size: 14px;
      line-height: 1.5;
    }

    .profile-affiliation {
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 0;
      line-height: 1.5;
    }

    /* About Section */
    .about-section {
      margin-bottom: 0;
    }

    .about-section p {
      margin-bottom: 14px;
      color: var(--text-primary);
      line-height: 1.5;
      font-size: 14px;
    }

    /* Social Links - Notion database style like Ayush's site */
    .social-links {
      display: flex;
      gap: 8px;
      margin-bottom: 0;
      margin-top: 20px;
      padding-top: 20px;
      padding-bottom: 20px;
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
      flex-wrap: nowrap;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      background: rgba(228, 244, 249, 1);
      border: 1px solid rgba(228, 244, 249, 1);
      border-radius: 3px;
      color: var(--text-primary);
      font-size: 14px;
      text-decoration: none;
      flex: 1;
    }

    @media (max-width: 600px) {
      .social-links {
        flex-wrap: wrap;
      }
      .social-link {
        flex: 1 1 calc(50% - 4px);
        min-width: calc(50% - 4px);
      }
    }

    .social-link svg {
      width: 16px;
      height: 16px;
    }

    /* Section Header */
    .section-header {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 12px;
      margin-top: 20px;
    }

    .section-header.green {
      color: var(--green-header);
    }

    .section-header.red {
      color: var(--red-header);
    }

    /* Experience Section */
    .experience-section {
      margin-bottom: 24px;
    }

    .experience-item {
      display: flex;
      gap: 12px;
      padding: 16px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .experience-content {
      flex: 1;
    }

    .experience-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 2px;
    }

    .experience-company {
      font-size: 13px;
      color: var(--text-primary);
      margin-bottom: 2px;
    }

    .experience-meta {
      font-size: 12px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .experience-description {
      font-size: 14px;
      color: var(--text-primary);
      line-height: 1.6;
      margin-bottom: 8px;
      padding-left: 0;
      list-style-position: outside;
      margin-left: 0px;
    }

    .experience-description li {
      margin-bottom: 8px;
    }

    .experience-skills {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: var(--text-secondary);
    }

    .experience-skills span {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    @media (max-width: 600px) {
      .experience-logo {
        width: 40px;
        height: 40px;
      }
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid var(--border-color);
      margin: 32px 0 24px;
    }
    /* Highlights Section */
    .highlights-section {
      margin-bottom: 48px;
    }

    .highlight-item {
      padding: 24px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .highlight-item:first-of-type {
      padding-top: 0;
    }

    .highlight-content h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
      line-height: 1.5;
    }

    .highlight-description {
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 10px;
      line-height: 1.6;
      padding-left: 0;
      list-style-position: outside;
      margin-left: 0px;
    }

    .highlight-description li {
      margin-bottom: 8px;
    }

    .highlight-links {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      background: rgba(228, 244, 249, 1);
      border: 1px solid rgba(228, 244, 249, 1);
      border-radius: 3px;
      font-size: 13px;
    }

    .highlight-links a {
      color: rgba(124, 130, 129, 1);
    }

    /* Other Socials - no borders */
    .social-links.no-border {
      border-top: none;
      border-bottom: none;
      margin-top: 0;
      padding-top: 0;
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 24px 0;
      border-top: none;
      margin-top: 32px;
      border-top: 1px solid var(--border-color);
    }

    .footer p {
      color: var(--text-secondary);
      font-size: 14px;
      margin: 0;
      line-height: 1.8;
    }

    /* Linked Pages */
    .linked-pages {
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid var(--border-color);
    }

    .linked-pages-title {
      font-size: 12px;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .linked-page {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 4px 0;
      color: var(--text-primary);
      font-size: 14px;
    }

    .linked-page:hover {
      background: var(--bg-secondary);
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-content">
      <span class="header-title">{name}</span>
    </div>
  </header>

  <!-- Main Content -->
  <main class="main">
    <!-- Page Title -->
    <h1 class="page-title">{name}</h1>

    <!-- Navigation Tabs -->
    <nav class="nav-tabs">
      <a href="#about" class="nav-tab">
        <span class="nav-tab-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
        </span>
        About Me
      </a>
      <a href="/projects" class="nav-tab">
        <span class="nav-tab-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
        </span>
        Projects
      </a>
    </nav>

    <!-- Profile Section -->
    <section class="profile-section" id="about">
      <div class="profile-image">
        <img src="/images/profile.jpg" alt={name} />
      </div>
      <div class="profile-info">
        <p class="profile-email"><a href={`mailto:${email}`}>{email.replace('@', '[at]')}</a></p>
        <p class="profile-tagline">{tagline}</p>
        <p class="profile-affiliation"><a href=#>{affiliation}</a></p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section">
      {aboutMe.map(paragraph => (
        <p>{paragraph}</p>
      ))}
    </section>

    <!-- Social Links -->
    <section class="social-links">
      <a href={socialLinks.resume} class="social-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"/></svg>
        Resume
      </a>
      <a href={socialLinks.github} class="social-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a href={socialLinks.linkedin} class="social-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a href={socialLinks.twitter} class="social-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
        Twitter
      </a>
    </section>

    <!-- Experience -->
    <h2 class="section-header green">Experience</h2>
    <section class="experience-section">
      {experience.map(exp => (
        <div class="experience-item">
          <div class="experience-content">
            <div class="experience-title">{exp.title}</div>
            <div class="experience-company">{exp.company} · {exp.type}</div>
            <div class="experience-meta">{exp.duration}<br/>{exp.location}</div>
            <ul class="experience-description">
              {exp.description.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="experience-skills">
              <span>{exp.skills.join(", ")}</span>
            </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Recent Projects -->
    <h2 class="section-header red">Recent Projects</h2>
    <section class="highlights-section">
      {topProjects.map(project => (
        <article class="highlight-item">
          <div class="highlight-content">
            <h3>{project.title}</h3>
            <ul class="highlight-description">
              {project.description.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="highlight-links">
              <span>📁</span>
              {project.links.map((link, i) => (
                <>
                  <a href={link.url}>[{link.label}]</a>{i < project.links.length - 1 ? ", " : ""}
                </>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Other Socials -->
    <h2 class="section-title">Other Socials:</h2>
    <section class="social-links no-border">
      <a href="https://hrootscraft.medium.com/" class="social-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
        Medium
