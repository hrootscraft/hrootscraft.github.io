---
const name = "Rutuja Bhure";

const projects = [
  {
    title: "Project One: A Deep Learning Framework for Design",
    authors: "Rutuja, Collaborator One, Collaborator Two",
    venue: "Journal/Conference Name, 2024",
    image: "/images/project1.png",
    links: [
      { label: "PDF", url: "#" },
      { label: "PROJECT PAGE", url: "#" }
    ]
  },
  {
    title: "Project Two: Building Scalable Web Applications",
    authors: "Rutuja, Collaborator Three",
    venue: "Conference/Journal Name, 2023",
    image: "/images/project2.png",
    links: [
      { label: "PDF", url: "#" },
      { label: "DEMO", url: "#" }
    ]
  },
  {
    title: "Project Three: Machine Learning for Data Analysis",
    authors: "Rutuja",
    venue: "Personal Project, 2023",
    image: "/images/project3.png",
    links: [
      { label: "PROJECT PAGE", url: "#" },
      { label: "CODE", url: "#" }
    ]
  },
  {
    title: "Project Four: Open Source Contribution",
    authors: "Rutuja, Open Source Community",
    venue: "GitHub, 2023",
    image: "/images/project4.png",
    links: [
      { label: "CODE", url: "#" }
    ]
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={`${name} - Projects`}>
  <title>Projects | {name}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style>
    :root {
      --text-primary: #37352f;
      --text-secondary: #787774;
      --text-link: #2eaadc;
      --bg-primary: #ffffff;
      --bg-secondary: #f7f6f3;
      --bg-hover: #eeeeec;
      --border-color: #e9e9e7;
      --red-header: rgba(2, 146, 123, 1);
      --nav-tab-bg: rgba(35, 131, 226, 0.07);
      --nav-tab-hover: rgba(35, 131, 226, 0.14);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol";
      background-color: var(--bg-primary);
      color: var(--text-primary);
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    a {
      color: var(--text-link);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    img {
      image-rendering: auto;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      transform: translateZ(0);
    }

    /* Header */
    .header {
      background: var(--bg-primary);
      padding: 10px 96px;
      border-bottom: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .header-title {
      font-size: 14px;
      font-weight: 400;
      color: var(--text-primary);
      text-decoration: none;
    }

    .header-title:hover {
      text-decoration: underline;
    }

    /* Main container */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 80px 96px 100px;
    }

    @media (max-width: 900px) {
      .header {
        padding: 10px 24px;
      }
      .main {
        padding: 40px 24px 60px;
        max-width: 100%;
      }
    }

    /* Page Title */
    .page-title {
      font-size: 40px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .page-subtitle {
      color: var(--text-secondary);
      font-size: 16px;
      margin-bottom: 40px;
      line-height: 1.6;
    }

    /* Section Header */
    .section-header {
      font-size: 24px;
      font-weight: 600;
      color: var(--red-header);
      margin-bottom: 20px;
    }

    /* Projects Section */
    .projects-section {
      margin-bottom: 48px;
    }

    .project-item {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 24px;
      padding: 24px 0;
      border-bottom: 1px solid var(--border-color);
    }

    .project-item:first-of-type {
      padding-top: 0;
    }

    .project-item:last-child {
      border-bottom: none;
    }

    @media (max-width: 700px) {
      .project-item {
        grid-template-columns: 1fr;
      }
    }

    .project-image {
      width: 180px;
      height: 120px;
      background: var(--bg-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 700px) {
      .project-image {
        width: 100%;
        height: 180px;
      }
    }

    .project-content h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 6px;
      line-height: 1.5;
    }

    .project-authors {
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 4px;
      line-height: 1.5;
    }

    .project-authors strong {
      font-weight: 600;
    }

    .project-venue {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 12px;
      line-height: 1.5;
    }

    .project-links {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      background: rgba(228, 244, 249, 1);
      border: 1px solid rgba(228, 244, 249, 1);
      border-radius: 3px;
      font-size: 14px;
    }

    .project-links a {
      color: rgba(124, 130, 129, 1);
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 24px 0;
      border-top: 1px solid var(--border-color);
      margin-top: 48px;
    }

    .footer p {
      color: var(--text-secondary);
      font-size: 14px;
      margin: 0;
      line-height: 1.8;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 16px;
      color: var(--text-secondary);
      font-size: 14px;
      transition: color 0.15s ease;
    }

    .back-link:hover {
      color: var(--text-link);
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-content">
      <a href="/" class="header-title">{name}</a>
    </div>
  </header>

  <!-- Main Content -->
  <main class="main">
    <!-- Page Title -->
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">A collection of my work and contributions</p>

    <!-- All Projects -->
    <h2 class="section-header">All Projects</h2>
    <section class="projects-section">
      {projects.map(project => (
        <article class="project-item">
          <div class="project-image">
            <img src={project.image} alt={project.title} />
          </div>
          <div class="project-content">
            <h3>{project.title}</h3>
            <p class="project-authors"><strong>{project.authors.split(',')[0]}</strong>{project.authors.includes(',') ? ',' + project.authors.split(',').slice(1).join(',') : ''}</p>
            <p class="project-venue">{project.venue}</p>
            <div class="project-links">
              <span>📁</span>
              {project.links.map((link, i) => (
                <>
                  <a href={link.url}>[{link.label}]</a>{i < project.links.length - 1 ? ", " : ""}
                </>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Footer -->
    <footer class="footer">
      <a href="/" class="back-link">← Back to Home</a>
      <p>©{name}, {new Date().getFullYear()}</p>
      <p>All Rights Reserved</p>
    </footer>
  </main>
</body>
</html>
